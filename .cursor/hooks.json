{
  "version": 1,
  "hooks": {
    "beforeReadFile": [
      {
        "command": ".cursor/hooks/deny-env-read.sh",
        "failClosed": true
      }
    ],
    "beforeTabFileRead": [
      {
        "command": ".cursor/hooks/deny-env-read.sh",
        "failClosed": true
      }
    ],
    "afterFileEdit": [
      {
        "command": ".cursor/hooks/go-fix.sh"
      }
    ]
  }
}
